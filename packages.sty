% --- Front matter ---
% Definerer formattering av begynnelsen av dokumentet
\newcommand{\frontmatter}{
    \pagenumbering{roman}   % Setter sidetallene til små romertall (i, ii, iii, …)
}


% --- Main matter ---
% Definerer formattering av hoveddel
\newcommand{\mainmatter}{
    \newpage
    \pagenumbering{arabic}  % Sidetall blir vanlig tall
}


